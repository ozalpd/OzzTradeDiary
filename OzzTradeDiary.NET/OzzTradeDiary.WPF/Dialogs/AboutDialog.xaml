<Window x:Class="TD.WPF.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TD.WPF.Dialogs"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        mc:Ignorable="d"
        Title="{x:Static i18n:ActionStrings.About}"
        Height="320" 
        Width="420" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Application Icon -->
        <Image x:Name="AppIcon"
               Grid.Row="0" Grid.RowSpan="6" Grid.Column="0"
               Width="192"
               Height="192"
               HorizontalAlignment="Center" 
               Margin="0,0,0,10"
               Source="/Assets/OzzTradeDiary-256.ico"/>

        <!-- Product Name -->
        <TextBlock Grid.Column="1" Grid.Row="1"
                   Text="{Binding Product}" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>

        <!-- Version -->
        <TextBlock Grid.Column="1" Grid.Row="2" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5">
            <Run Text="{x:Static i18n:CommonStrings.Version}" FontWeight="SemiBold"/>
            <Run Text="{Binding Version, Mode=OneWay}"/>
        </TextBlock>

        <!-- Description -->
        <TextBlock Grid.Column="1" Grid.Row="3" 
                   Text="{Binding Description}" 
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,0,5"/>

        <!-- Copyright -->
        <TextBlock Grid.Column="1" Grid.Row="4" 
                   Text="{Binding Copyright}" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- GitHub Link -->
        <TextBlock Grid.Column="1" Grid.Row="5" 
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top">
            <Hyperlink NavigateUri="https://github.com/ozalpd/OzzTradeDiary" 
                       RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="{x:Static i18n:CommonStrings.ViewOnGitHub}"/>
            </Hyperlink>
        </TextBlock>

        <!-- OK Button -->
        <Button Grid.ColumnSpan="2" Grid.Row="6" 
                Width="80" Height="28" Margin="0,8,0,0"
                Content="{x:Static i18n:ActionStrings.OK}" IsDefault="True"
                Click="OkButton_Click"
                HorizontalAlignment="Center"/>
    </Grid>
</Window>

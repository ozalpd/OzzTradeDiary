                                           Text="{Binding RoundedPlannedTP, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="7" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.ExecutedTP}"/>
                                <TextBlock Grid.Column="4" Grid.Row="7"
                                           Text="{Binding RoundedExecutedTP, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 10: PlannedRiskAmount / RealizedRiskAmount -->
                                <TextBlock Grid.Column="0" Grid.Row="8" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.PlannedRiskAmount}"/>
                                <TextBlock Grid.Column="1" Grid.Row="8"
                                           Text="{Binding PlannedRiskAmount, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="8" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.RealizedRiskAmount}"/>
                                <TextBlock Grid.Column="4" Grid.Row="8"
                                           Text="{Binding RealizedRiskAmount, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 11: PlannedProfit / RealizedProfitLoss -->
                                <TextBlock Grid.Column="0" Grid.Row="9" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.PlannedProfit}"/>
                                <TextBlock Grid.Column="1" Grid.Row="9"
                                           Text="{Binding PlannedProfitLoss, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="9" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}"/>
                                <TextBlock Grid.Column="4" Grid.Row="9"
                                           Text="{Binding RealizedProfitLoss, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 12: PlannedRiskRewardRatio / NetProfitLoss -->
                                <TextBlock Grid.Column="0" Grid.Row="10" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.PlannedRiskRewardRatio}"/>
                                <TextBlock Grid.Column="1" Grid.Row="10"
                                           Text="{Binding PlannedRiskRewardRatio, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="10" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.NetProfitLoss}"/>
                                <TextBlock Grid.Column="4" Grid.Row="10"
                                           Text="{Binding NetProfitLoss, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 13: TotalFeesCalculated / TotalFeesCorrected -->
                                <TextBlock Grid.Column="0" Grid.Row="11" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.TotalFeesCalculated}"/>
                                <TextBlock Grid.Column="1" Grid.Row="11"
                                           Text="{Binding TotalFeesCalculated, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="11" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.TotalFeesCorrected}"/>
                                <TextBlock Grid.Column="4" Grid.Row="11"
                                           Text="{Binding TotalFeesCorrected, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 14: FundingFeeTotal / UpdatedAt -->
                                <TextBlock Grid.Column="0" Grid.Row="12" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.FundingFeeTotal}"/>
                                <TextBlock Grid.Column="1" Grid.Row="12"
                                           Text="{Binding FundingFeeTotal, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="12" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.UpdatedAt}"/>
                                <TextBlock Grid.Column="4" Grid.Row="12"
                                           Text="{Binding UpdatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}, Mode=OneWay}" Margin="0,0,0,8"/>

                                <!-- Row 15: Tags -->
                                <TextBlock Grid.Column="0" Grid.Row="13" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.Tags}"/>
                                <TextBlock Grid.Column="1" Grid.Row="13" Grid.ColumnSpan="5"
                                           Text="{Binding Tags, Mode=OneWay}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            </Grid>

                            <!-- ═══ Order Data Grids and Command Buttons ═══ -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- ═══ Entry Orders ═══ -->
                                <TextBlock Grid.Row="0" Margin="0,4,8,0" FontWeight="Bold"
                                           Text="{x:Static i18n:LocalizedStrings.EntryOrders}"/>

                                <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="0" Orientation="Horizontal">
                                    <Button Style="{StaticResource IconButtonStyle-22x18}"
                                            ToolTip="{x:Static i18n:LocalizedStrings.AddEntryOrder}"
                                            Command="{Binding EntryOrderCreateCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Viewbox Width="14" Height="14">
                                            <Path>
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Fill" Value="#0044D7"/>
                                                        <Setter Property="Data" Value="{StaticResource plus-circle}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Fill" Value="#A0A0A0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Fill" Value="#000000"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Viewbox>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle-22x18}"
                                            ToolTip="{x:Static i18n:ActionStrings.Edit}"
                                            Command="{Binding EntryOrderEditCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Viewbox Width="14" Height="14">
                                            <Path>
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Fill" Value="#0044D7"/>
                                                        <Setter Property="Data" Value="{StaticResource pencil-square}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Fill" Value="#A0A0A0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Fill" Value="#000000"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Viewbox>
                                    </Button>

                                    <Button Style="{StaticResource IconButtonStyle-22x18}"
                                            ToolTip="{x:Static i18n:LocalizedStrings.DeleteEntryOrder}"
                                            Background="#C80000"
                                            Command="{Binding EntryOrderDeleteCommand}"
                                            CommandParameter="{Binding}">
                                        <Viewbox Width="14" Height="14">
                                            <Path>
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Fill" Value="#F8F8F8"/>
                                                        <Setter Property="Data" Value="{StaticResource trash3}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Fill" Value="#A0A0A0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Fill" Value="#C80000"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                                <DataGrid Grid.Row="1" Grid.ColumnSpan="6" Margin="-6,0,-4,4"
                                          ItemsSource="{Binding EntryOrders}"
                                          SelectedItem="{Binding SelectedEntryOrder}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          CanUserSortColumns="True"
                                          GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderType}" Width="64"
                                                            Binding="{Binding OrderType}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderPrice}" Width="72"
                                                            Binding="{Binding OrderPrice}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledPrice}" Width="72"
                                                            Binding="{Binding FilledPrice}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderQuantity}" Width="80"
                                                            Binding="{Binding OrderQuantity}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledQuantity}" Width="80"
                                                            Binding="{Binding FilledQuantity}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderValue}" Width="72"
                                                            Binding="{Binding OrderValue, StringFormat=\{0:N2\}}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledValue}" Width="72"
                                                            Binding="{Binding FilledValue, StringFormat=\{0:N2\}}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledTime}" Width="*"
                                                            Binding="{Binding FilledTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"/>
                                    </DataGrid.Columns>
                                </DataGrid>


                                <!-- ═══ Stop Loss Orders ═══ -->
                                <TextBlock Grid.Row="2" Margin="0,4,8,0" FontWeight="Bold"
                                           Text="{x:Static i18n:LocalizedStrings.StopLossOrders}"/>

                                <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Orientation="Horizontal">
                                    <Button Style="{StaticResource IconButtonStyle-22x18}"
                                            ToolTip="{x:Static i18n:LocalizedStrings.AddStopLossOrder}"
                                            Command="{Binding StopLossOrderCreateCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Viewbox Width="14" Height="14">
                                            <Path>
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Fill" Value="#0044D7"/>
                                                        <Setter Property="Data" Value="{StaticResource plus-circle}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">

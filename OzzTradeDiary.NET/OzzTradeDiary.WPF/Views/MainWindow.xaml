                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Fill" Value="#A0A0A0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Fill" Value="#000000"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Viewbox>
                                    </Button>

                                    <Button Style="{StaticResource IconButtonStyle-22x18}"
                                            ToolTip="{x:Static i18n:LocalizedStrings.DeleteTakeProfitOrder}"
                                            Background="#C80000"
                                            Command="{Binding TakeProfitOrderDeleteCommand}"
                                            CommandParameter="{Binding}">
                                        <Viewbox Width="14" Height="14">
                                            <Path>
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Fill" Value="#F8F8F8"/>
                                                        <Setter Property="Data" Value="{StaticResource trash3}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Fill" Value="#A0A0A0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Fill" Value="#C80000"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                                <DataGrid Grid.Row="5" Grid.ColumnSpan="6" Margin="-6,0,-4,4"
                                          ItemsSource="{Binding TakeProfitOrders}"
                                          SelectedItem="{Binding SelectedTakeProfitOrder}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          CanUserSortColumns="True"
                                          GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderType}" Width="64"
                                                            Binding="{Binding OrderType}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderPrice}" Width="72"
                                                            Binding="{Binding OrderPrice}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledPrice}" Width="72"
                                                            Binding="{Binding FilledPrice}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderQuantity}" Width="80"
                                                            Binding="{Binding OrderQuantity}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledQuantity}" Width="80"
                                                            Binding="{Binding FilledQuantity}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.OrderProfitAmount}" Width="72"
                                                            Binding="{Binding OrderProfitAmount, StringFormat=\{0:N2\}}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledProfitAmount}" Width="72"
                                                            Binding="{Binding FilledProfitAmount, StringFormat=\{0:N2\}}"
                                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledTime}" Width="*"
                                                            Binding="{Binding FilledTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <!-- ═══ Notes ═══ -->
                            <Grid Grid.Row="2"  DataContext="{Binding SelectedTrade}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto" MinHeight="64"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto" MinHeight="64"/>
                                </Grid.RowDefinitions>
                                <!-- ═══ Setup Notes ═══ -->
                                <TextBlock Grid.Row="0" Margin="-4,8,8,0"
                                           Text="{x:Static i18n:LocalizedStrings.SetupNotes}" FontWeight="Bold"/>
                                <Border Grid.Row="1" Margin="-4,0">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding SetupNotes, Mode=OneWay}" Margin="0,0,4,8"/>
                                </Border>

                                <!-- ═══ Review Notes ═══ -->
                                <TextBlock Grid.Row="2" Margin="-4,8,8,0"
                                           Text="{x:Static i18n:LocalizedStrings.ReviewNotes}" FontWeight="Bold"/>
                                <Border Grid.Row="3" Margin="-4,0">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding ReviewNotes, Mode=OneWay}" Margin="0,0,4,8"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

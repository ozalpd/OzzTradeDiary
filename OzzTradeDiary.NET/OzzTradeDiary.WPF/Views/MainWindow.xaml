<Window x:Class="TD.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TD.Models;assembly=OzzTradeDiary"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        mc:Ignorable="d"
        Title="Ozz Trade Diary"
        Height="700" Width="1440" MinHeight="520" MinWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="{x:Static i18n:ActionStrings.File}">
                <MenuItem Header="{x:Static i18n:ActionStrings.Import}" Command="{Binding ImportCommand}" />
                <MenuItem Header="{x:Static i18n:ActionStrings.Export}" Command="{Binding ExportCommand}" />
                <Separator />
                <MenuItem Header="{x:Static i18n:ActionStrings.Exit}" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Edit}">
                <MenuItem Header="{x:Static i18n:LocalizedStrings.AddTrade}" Command="{Binding TradeHistory.TradeCreateCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <MenuItem Header="{x:Static i18n:LocalizedStrings.EditTrade}" Command="{Binding TradeHistory.TradeEditCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <MenuItem Header="{x:Static i18n:LocalizedStrings.DeleteTrade}" Command="{Binding TradeHistory.TradeDeleteCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.View}">
                <MenuItem Header="{x:Static i18n:ActionStrings.Summary}" Command="{Binding ShowSummaryCommand}" />
                <MenuItem Header="{x:Static i18n:ActionStrings.Charts}" Command="{Binding ShowChartsCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Maintenance}">
                <MenuItem Header="{x:Static i18n:ActionStrings.ManageData}" Command="{Binding ShowMaintenanceCommand}">
                    <MenuItem.Icon>
                        <Path Fill="#0044D7" Data="{StaticResource gear-wide-connected}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Help}">
                <MenuItem Header="{x:Static i18n:ActionStrings.About}" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <Path Fill="#1D9BF0" Data="{StaticResource info-circle-fill}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Upper Toolbars -->
        <StackPanel Grid.Row="1" DataContext="{Binding TradeHistory}" Orientation="Horizontal" VerticalAlignment="Center">
            <ToolBar>
                <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddTrade}"
                                Command="{Binding TradeCreateCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Viewbox Width="14" Height="14">
                        <Path>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#0044D7"/>
                                    <Setter Property="Data" Value="{StaticResource plus-circle}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#A0A0A0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="#000000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </Button>
                <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.EditTrade}"
                                Command="{Binding TradeEditCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Viewbox Width="14" Height="14">
                        <Path>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#0044D7"/>
                                    <Setter Property="Data" Value="{StaticResource pencil-square}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#A0A0A0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="#000000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </Button>

                <Separator/>
                <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.DeleteTrade}"
                                Background="#C80000"
                                Command="{Binding TradeDeleteCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Viewbox Width="14" Height="14">
                        <Path>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#F8F8F8"/>
                                    <Setter Property="Data" Value="{StaticResource trash3}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#A0A0A0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="#C80000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </Button>
            </ToolBar>

            <ToolBar>
                <!-- Entry date range -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.EntryTime}"
                           VerticalAlignment="Center" Margin="4,0,4,0"/>
                <DatePicker Width="120" SelectedDate="{Binding QueryVM.EntryTimeMin, Mode=TwoWay}"
                            ToolTip="From"/>
                <Viewbox Width="12" Height="12" Margin="2,0,4,0">
                    <Path Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                          Data="{StaticResource arrow-right}"/>
                </Viewbox>
                <DatePicker Width="120" SelectedDate="{Binding QueryVM.EntryTimeMax, Mode=TwoWay}"
                            ToolTip="To"/>

                <Separator/>
            </ToolBar>
        </StackPanel>

        <!-- Filter Toolbar -->
        <ToolBar Grid.Row="2" DataContext="{Binding TradeHistory}">
            <!-- Trading Account filter -->
            <ComboBox x:Name="TradingAccountComboBox" Width="160"
                      ItemsSource="{Binding TradingAccounts}"
                      DisplayMemberPath="Title"
                      SelectedValuePath="Id"
                      SelectedItem="{Binding SelectedTradingAccount}"
                      SelectedValue="{Binding QueryVM.ByTradingAccountId, Mode=TwoWay}">
                <ComboBox.Resources>
                    <CollectionViewSource x:Key="cvs" Source="{Binding TradingAccounts}"/>
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock Text="{x:Static i18n:LocalizedStrings.TradingAccount}"
                       VerticalAlignment="Stretch" Margin="-154,3,18,3"
                       Foreground="#686868" Background="White"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFocused, ElementName=TradingAccountComboBox}" Value="False" />
                                    <Condition Binding="{Binding Text.Length, ElementName=TradingAccountComboBox, FallbackValue=0}" Value="0" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Separator/>

            <!-- Symbol filter -->
            <ComboBox x:Name="SymbolComboBox" Width="140"
                      ItemsSource="{Binding Symbols}"
                      DisplayMemberPath="TickerFull"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding QueryVM.BySymbolId, Mode=TwoWay}"/>
            <TextBlock Text="{x:Static i18n:LocalizedStrings.Symbol}"
                       VerticalAlignment="Stretch" Margin="-134,3,18,3"
                       Foreground="#686868" Background="White"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFocused, ElementName=SymbolComboBox}" Value="False" />
                                    <Condition Binding="{Binding Text.Length, ElementName=SymbolComboBox, FallbackValue=0}" Value="0" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Separator/>


            <!-- Load button -->
            <Button Command="{Binding TradesLoadCommand}"
                    ToolTip="{x:Static i18n:ActionStrings.Load}"
                    Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static i18n:ActionStrings.Load}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Viewbox Width="14" Height="14">
                        <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                              Data="{StaticResource search}"/>
                    </Viewbox>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Master / Detail content area -->
        <Grid Grid.Row="3" DataContext="{Binding TradeHistory}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42*" MinWidth="600"/>
                <ColumnDefinition Width="257*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="60*" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- Trade list + pager (master) -->
            <Grid Grid.Column="0" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding Trades}"
                          SelectedItem="{Binding SelectedTrade, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.EntryTime}" Width="80"
                                            Binding="{Binding EntryTime, StringFormat=\{0:yyyy-MM-dd\}}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExitTime}" Width="80"
                                            Binding="{Binding ExitTime, StringFormat=\{0:yyyy-MM-dd\}}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TradingAccount}" Width="100"
                                            Binding="{Binding TradingAccount.Title}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.EntryMethod}" Width="80"
                                            Binding="{Binding EntryMethod}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Symbol}" Width="100"
                                            Binding="{Binding Symbol.TickerFull}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TradeDirection}" Width="70"
                                            Binding="{Binding TradeDirection}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledQuantity}" Width="80"
                                            Binding="{Binding FilledQuantity, StringFormat=\{0:N4\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}" Width="80"
                                            Binding="{Binding ExecutedEntryPrice, StringFormat=\{0:N4\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.PlannedProfitLoss}" Width="80"
                                            Binding="{Binding PlannedProfitLoss, StringFormat=\{0:N2\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}" Width="80"
                                            Binding="{Binding RealizedProfitLoss, StringFormat=\{0:N2\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.RealizedR}" Width="60"
                                            Binding="{Binding RealizedR, StringFormat=\{0:N2\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.IsFullyClosed}" Width="70"
                                                Binding="{Binding IsFullyClosed}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pager bar -->
                <Border Grid.Row="1"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        Padding="6,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding QueryVM.RecordsInfo}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                        <!-- Page navigation (centred) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Button Command="{Binding TradesPrevPageCommand}"
                                    Style="{StaticResource IconButtonStyle-28x24}"
                                    ToolTip="Previous page">
                                <Viewbox Width="12" Height="12">
                                    <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Data="{StaticResource chevron-left}"/>
                                </Viewbox>
                            </Button>
                            
                            <TextBlock Grid.Column="0" Text="{Binding QueryVM.PageInfo}"
                                       VerticalAlignment="Center" Margin="8,0,8,0"
                                       FontSize="12" FontWeight="SemiBold"/>

                            <Button Command="{Binding TradesNextPageCommand}"
                                    Style="{StaticResource IconButtonStyle-28x24}"
                                    ToolTip="Next page">
                                <Viewbox Width="12" Height="12">
                                    <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Data="{StaticResource chevron-right}"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>

                        <!-- Page size selector -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static i18n:CommonStrings.PerPage}"
                                       VerticalAlignment="Center" Margin="2,0"
                                       FontSize="12"/>
                            <TextBlock Text=":"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="12"/>
                            <ComboBox SelectedValue="{Binding QueryVM.PageSize, Mode=TwoWay}"
                                      FontSize="12" Width="55" Height="22" Padding="4,1">
                                <sys:Int32>20</sys:Int32>
                                <sys:Int32>50</sys:Int32>
                                <sys:Int32>100</sys:Int32>
                                <sys:Int32>200</sys:Int32>
                                <sys:Int32>500</sys:Int32>
                                <sys:Int32>1000</sys:Int32>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="2" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>

            <!-- Trade detail (detail pane) -->
            <ScrollViewer Grid.Column="3" VerticalScrollBarVisibility="Auto">
                <Grid Margin="8" DataContext="{Binding SelectedTrade}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- 0: header -->
                        <!-- Identity -->
                        <RowDefinition Height="Auto"/>
                        <!-- 1: Symbol -->
                        <RowDefinition Height="Auto"/>
                        <!-- 2: TradingAccount -->
                        <RowDefinition Height="Auto"/>
                        <!-- 3: EntryTime -->
                        <RowDefinition Height="Auto"/>
                        <!-- 4: ExitTime -->
                        <RowDefinition Height="Auto"/>
                        <!-- 5: TradeDirection -->
                        <RowDefinition Height="Auto"/>
                        <!-- 6: EntryMethod -->
                        <!-- Position -->
                        <RowDefinition Height="Auto"/>
                        <!-- 7: OrderQuantity -->
                        <RowDefinition Height="Auto"/>
                        <!-- 8: FilledQuantity -->
                        <!-- Entry -->
                        <RowDefinition Height="Auto"/>
                        <!-- 9: PlannedEntryPrice -->
                        <RowDefinition Height="Auto"/>
                        <!-- 10: ExecutedEntryPrice -->
                        <!-- Stop Loss -->
                        <RowDefinition Height="Auto"/>
                        <!-- 11: PlannedSL -->
                        <RowDefinition Height="Auto"/>
                        <!-- 12: ExecutedSL -->
                        <!-- Take Profit -->
                        <RowDefinition Height="Auto"/>
                        <!-- 13: PlannedTP -->
                        <RowDefinition Height="Auto"/>
                        <!-- 14: ExecutedTP -->
                        <!-- P/L & Risk -->
                        <RowDefinition Height="Auto"/>
                        <!-- 15: PlannedRiskRewardRatio -->
                        <RowDefinition Height="Auto"/>
                        <!-- 16: PlannedProfitLoss -->
                        <RowDefinition Height="Auto"/>
                        <!-- 17: RealizedProfitLoss -->
                        <RowDefinition Height="Auto"/>
                        <!-- 18: RealizedR -->
                        <!-- Status -->
                        <RowDefinition Height="Auto"/>
                        <!-- 19: IsFullyClosed -->
                        <RowDefinition Height="Auto"/>
                        <!-- 20: UpdatedAt -->
                        <!-- Notes -->
                        <RowDefinition Height="Auto"/>
                        <!-- 21: SetupNotes label -->
                        <RowDefinition Height="Auto" MinHeight="48"/>
                        <!-- 22: SetupNotes value -->
                        <RowDefinition Height="Auto"/>
                        <!-- 23: ReviewNotes label -->
                        <RowDefinition Height="Auto" MinHeight="48"/>
                        <!-- 24: ReviewNotes value -->
                    </Grid.RowDefinitions>

                    <!-- Header
                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"
                               Text="{x:Static i18n:LocalizedStrings.TradeHistory}"/>
 -->
                    <!-- Identity -->

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Symbol.Ticker}" FontWeight="Bold" FontSize="16" Margin="0,2,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding TradingAccount.Title}" FontWeight="Bold" Margin="0,4,0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.EntryTime}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EntryTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.ExitTime}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ExitTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.TradeDirection}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TradeDirection}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.EntryMethod}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding EntryMethod}" Margin="0,2,0,2"/>

                    <!-- Position sizing -->
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.OrderQuantity}" FontWeight="Bold" Margin="0,6,8,2"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding OrderQuantity, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,6,0,2"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.FilledQuantity}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding FilledQuantity, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,2,0,2"/>

                    <!-- Entry prices -->
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.PlannedEntryPrice}" FontWeight="Bold" Margin="0,6,8,2"/>
                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding PlannedEntryPrice, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,6,0,2"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding ExecutedEntryPrice, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,2,0,2"/>

                    <!-- Stop loss -->
                    <TextBlock Grid.Row="11" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.PlannedSL}" FontWeight="Bold" Margin="0,6,8,2"/>
                    <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding PlannedSL, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,6,0,2"/>

                    <TextBlock Grid.Row="12" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.ExecutedSL}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding ExecutedSL, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,2,0,2"/>

                    <!-- Take profit -->
                    <TextBlock Grid.Row="13" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.PlannedTP}" FontWeight="Bold" Margin="0,6,8,2"/>
                    <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding PlannedTP, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,6,0,2"/>

                    <TextBlock Grid.Row="14" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.ExecutedTP}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding ExecutedTP, StringFormat=\{0:N4\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,2,0,2"/>

                    <!-- P/L & Risk -->
                    <TextBlock Grid.Row="15" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.PlannedRiskRewardRatio}" FontWeight="Bold" Margin="0,6,8,2"/>
                    <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding PlannedRiskRewardRatio, StringFormat=\{0:N2\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,6,0,2"/>

                    <TextBlock Grid.Row="16" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.PlannedProfitLoss}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding PlannedProfitLoss, StringFormat=\{0:N2\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="17" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="17" Grid.Column="1" Text="{Binding RealizedProfitLoss, StringFormat=\{0:N2\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="18" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.RealizedR}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="18" Grid.Column="1" Text="{Binding RealizedR, StringFormat=\{0:N2\}}" Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,2,0,2"/>

                    <!-- Status -->
                    <TextBlock Grid.Row="19" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.IsFullyClosed}" FontWeight="Bold" Margin="0,6,8,2"/>
                    <CheckBox  Grid.Row="19" Grid.Column="1" IsChecked="{Binding IsFullyClosed, Mode=OneWay}" IsEnabled="False" Margin="0,6,0,2"/>

                    <TextBlock Grid.Row="20" Grid.Column="0" Text="{x:Static i18n:LocalizedStrings.UpdatedAt}" FontWeight="Bold" Margin="0,2,8,2"/>
                    <TextBlock Grid.Row="20" Grid.Column="1" Text="{Binding UpdatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Margin="0,2,0,2"/>

                    <!-- Notes -->
                    <TextBlock Grid.Row="21" Grid.Column="0" Grid.ColumnSpan="2" Text="{x:Static i18n:LocalizedStrings.SetupNotes}" FontWeight="Bold" Margin="0,6,0,2"/>
                    <TextBlock Grid.Row="22" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding SetupNotes}" TextWrapping="Wrap" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="23" Grid.Column="0" Grid.ColumnSpan="2" Text="{x:Static i18n:LocalizedStrings.ReviewNotes}" FontWeight="Bold" Margin="0,6,0,2"/>
                    <TextBlock Grid.Row="24" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding ReviewNotes}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

<Window x:Class="TD.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TD.Models;assembly=OzzTradeDiary"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        xmlns:converters="clr-namespace:TD.WPF.Converters"
        xmlns:designTime="clr-namespace:TD.WPF.DesignTime"
        mc:Ignorable="d"
        Title="Ozz Trade Diary"
        Height="980" Width="1440" MinHeight="540" MinWidth="1280">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="{x:Static i18n:ActionStrings.File}">
                <MenuItem Header="{x:Static i18n:ActionStrings.Import}" Command="{Binding ImportCommand}" />
                <MenuItem Header="{x:Static i18n:ActionStrings.Export}" Command="{Binding ExportCommand}" />
                <Separator />
                <MenuItem Header="{x:Static i18n:ActionStrings.Exit}" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Edit}">
                <MenuItem Header="{x:Static i18n:LocalizedStrings.AddTrade}" Command="{Binding TradeHistory.TradeCreateCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <MenuItem Header="{x:Static i18n:LocalizedStrings.EditTrade}" Command="{Binding TradeHistory.TradeEditCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <MenuItem Header="{x:Static i18n:LocalizedStrings.DeleteTrade}" Command="{Binding TradeHistory.TradeDeleteCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.View}">
                <MenuItem Header="{x:Static i18n:ActionStrings.Summary}" Command="{Binding ShowSummaryCommand}" />
                <MenuItem Header="{x:Static i18n:ActionStrings.Charts}" Command="{Binding ShowChartsCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Maintenance}">
                <MenuItem Header="{x:Static i18n:ActionStrings.ManageData}" Command="{Binding ShowMaintenanceCommand}">
                    <MenuItem.Icon>
                        <Path Fill="#0044D7" Data="{StaticResource gear-wide-connected}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Help}">
                <MenuItem Header="{x:Static i18n:ActionStrings.About}" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <Path Fill="#1D9BF0" Data="{StaticResource info-circle-fill}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Upper Toolbars -->
        <StackPanel Grid.Row="1" DataContext="{Binding TradeHistory}" Orientation="Horizontal" VerticalAlignment="Center">
            <ToolBar>
                <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddTrade}"
                                Command="{Binding TradeCreateCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Viewbox Width="14" Height="14">
                        <Path Margin="-2">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#0044D7"/>
                                    <Setter Property="Data" Value="{StaticResource plus-circle}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#A0A0A0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="#000000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </Button>
                <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.EditTrade}"
                                Command="{Binding TradeEditCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Viewbox Width="14" Height="14">
                        <Path Margin="-2">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#0044D7"/>
                                    <Setter Property="Data" Value="{StaticResource pencil-square}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#A0A0A0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="#000000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </Button>

                <Separator/>
                <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.DeleteTrade}"
                                Background="#C80000"
                                Command="{Binding TradeDeleteCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Viewbox Width="14" Height="14">
                        <Path Margin="-1">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#F8F8F8"/>
                                    <Setter Property="Data" Value="{StaticResource trash3}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#A0A0A0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="#C80000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </Button>
                <Separator/>

                <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.Trade}"
                                Command="{Binding TradeDetailCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Viewbox Width="18" Height="18">
                        <Path Margin="-3,0,0,-3">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#0044D7"/>
                                    <Setter Property="Data" Value="{StaticResource currency-exchange}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#A0A0A0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="#000000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </Button>
            </ToolBar>

            <ToolBar>
                <!-- Entry date range -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.EntryTime}"
                           VerticalAlignment="Center" Margin="4,0,4,0"/>
                <DatePicker Width="120" SelectedDate="{Binding QueryVM.EntryTimeMin, Mode=TwoWay}"
                            ToolTip="From"/>
                <Viewbox Width="12" Height="12" Margin="2,0,4,0">
                    <Path Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                          Data="{StaticResource arrow-right}"/>
                </Viewbox>
                <DatePicker Width="120" SelectedDate="{Binding QueryVM.EntryTimeMax, Mode=TwoWay}"
                            ToolTip="To"/>

                <Separator/>
            </ToolBar>
        </StackPanel>

        <!-- Filter Toolbar -->
        <ToolBar Grid.Row="2" DataContext="{Binding TradeHistory}">
            <!-- Trading Account filter -->
            <ComboBox x:Name="TradingAccountComboBox" Width="160"
                      ItemsSource="{Binding TradingAccounts}"
                      DisplayMemberPath="Title"
                      SelectedValuePath="Id"
                      SelectedItem="{Binding FilterTradingAccount }"
                      SelectedValue="{Binding QueryVM.ByTradingAccountId, Mode=TwoWay}">
                <ComboBox.Resources>
                    <CollectionViewSource x:Key="cvs" Source="{Binding TradingAccounts}"/>
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock Text="{x:Static i18n:LocalizedStrings.TradingAccount}"
                       VerticalAlignment="Stretch" Margin="-154,3,18,3"
                       Foreground="#686868" Background="White"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFocused, ElementName=TradingAccountComboBox}" Value="False" />
                                    <Condition Binding="{Binding Text.Length, ElementName=TradingAccountComboBox, FallbackValue=0}" Value="0" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Separator/>

            <!-- Symbol filter -->
            <ComboBox x:Name="SymbolComboBox" Width="140"
                      ItemsSource="{Binding Symbols}"
                      DisplayMemberPath="TickerFull"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding QueryVM.BySymbolId, Mode=TwoWay}"/>
            <TextBlock Text="{x:Static i18n:LocalizedStrings.Symbol}"
                       VerticalAlignment="Stretch" Margin="-134,3,18,3"
                       Foreground="#686868" Background="White"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFocused, ElementName=SymbolComboBox}" Value="False" />
                                    <Condition Binding="{Binding Text.Length, ElementName=SymbolComboBox, FallbackValue=0}" Value="0" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Separator/>


            <!-- Load button -->
            <Button Command="{Binding TradesLoadCommand}"
                    ToolTip="{x:Static i18n:ActionStrings.Load}"
                    Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static i18n:ActionStrings.Load}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Viewbox Width="14" Height="14">
                        <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                              Data="{StaticResource search}"/>
                    </Viewbox>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Master / Detail content area -->
        <Grid Grid.Row="3" DataContext="{Binding TradeHistory}" d:DataContext="{d:DesignInstance Type=designTime:MockTradeHistoryVM, IsDesignTimeCreatable=True}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="480"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Trade list + pager (master) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding Trades}"
                          SelectedItem="{Binding SelectedTrade, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                    <DataGrid.Columns>
                        <!-- Identity / context -->
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TradeDirection}" Width="70"
                                            Binding="{Binding TradeDirection}"
                                            CellStyle="{StaticResource TradeDirectionCellStyleLight}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TradeStatus}" Width="90"
                                            Binding="{Binding TradeStatus}"
                                            CellStyle="{StaticResource TradeStatusCellStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TradingAccount}" Width="110"
                                            Binding="{Binding TradingAccount.Title}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Symbol}" Width="110"
                                            Binding="{Binding Symbol.TickerFull}"/>
                        <!-- Timing -->
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.EntryTime}" Width="90"
                                            Binding="{Binding EntryTime, StringFormat=\{0:yyyy-MM-dd\}}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExitTime}" Width="90"
                                            Binding="{Binding ExitTime, StringFormat=\{0:yyyy-MM-dd\}}"/>
                        <!-- Plan -->
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.PlannedEntryPrice}" Width="90"
                                            Binding="{Binding RoundedPlannedEntryPrice}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <!-- Execution -->
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilledQuantity}" Width="80"
                                            Binding="{Binding RoundedFilledQuantity}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}" Width="90"
                                            Binding="{Binding RoundedExecutedEntryPrice}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <!-- P&L -->
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.PlannedProfit}" Width="80"
                                            Binding="{Binding PlannedProfitLoss, StringFormat=\{0:N2\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}" Width="80"
                                            Binding="{Binding RealizedProfitLoss, StringFormat=\{0:N2\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.NetProfitLoss}" Width="80"
                                            Binding="{Binding NetProfitLoss, StringFormat=\{0:N2\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <!-- Risk -->
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.PlannedRiskRewardRatio}" Width="60"
                                            Binding="{Binding PlannedRiskRewardRatio, StringFormat=\{0:N2\}}"
                                            ElementStyle="{StaticResource RightAlignedTextBlockStyle}"/>
                        <!-- Tags -->
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Tags}" Width="*"
                                            Binding="{Binding Tags}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pager bar -->
                <Border Grid.Row="1"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        Padding="6,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding QueryVM.RecordsInfo}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                        <!-- Page navigation (centred) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Button Command="{Binding TradesPrevPageCommand}"
                                    Style="{StaticResource IconButtonStyle-28x24}"
                                    ToolTip="Previous page">
                                <Viewbox Width="12" Height="12">
                                    <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Data="{StaticResource chevron-left}"/>
                                </Viewbox>
                            </Button>

                            <TextBlock Grid.Column="0" Text="{Binding QueryVM.PageInfo}"
                                       VerticalAlignment="Center" Margin="8,0,8,0"
                                       FontSize="12" FontWeight="SemiBold"/>

                            <Button Command="{Binding TradesNextPageCommand}"
                                    Style="{StaticResource IconButtonStyle-28x24}"
                                    ToolTip="Next page">
                                <Viewbox Width="12" Height="12">
                                    <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Data="{StaticResource chevron-right}"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>

                        <!-- Page size selector -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static i18n:CommonStrings.PerPage}"
                                       VerticalAlignment="Center" Margin="2,0"
                                       FontSize="12"/>
                            <TextBlock Text=":"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="12"/>
                            <ComboBox SelectedValue="{Binding QueryVM.PageSize, Mode=TwoWay}"
                                      FontSize="12" Width="55" Height="22" Padding="4,1">
                                <sys:Int32>20</sys:Int32>
                                <sys:Int32>50</sys:Int32>
                                <sys:Int32>100</sys:Int32>
                                <sys:Int32>200</sys:Int32>
                                <sys:Int32>500</sys:Int32>
                                <sys:Int32>1000</sys:Int32>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Splitter
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
-->
            <!-- Trade detail (detail pane) -->
            <Border Grid.Column="1" Padding="4,0" d:Visibility="Visible">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTrade}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header: Account + Symbol -->
                    <Grid DataContext="{Binding SelectedTrade}" Grid.Row="0" Background="#FF468DFF">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Column="0" Grid.Row="0" Margin="4,8,4,4"
                                   FontWeight="Bold" FontSize="16" Foreground="#FFFFF8F8"
                                   Text="{Binding TradingAccount.Title, Mode=OneWay}"
                                   HorizontalAlignment="Center"/>

                        <Border Grid.Column="1" Grid.Row="0" Margin="4"
                                BorderThickness="2" CornerRadius="4"
                                Background="{Binding TradeStatus, Converter={StaticResource TradeStatusLightBgColor}}">
                            <TextBlock Margin="2" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontSize="12"
                                       Text="{Binding TradeStatus, Mode=OneWay}"/>
                        </Border>

                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="4,4,4,8"
                                   FontWeight="Bold" FontSize="14" Foreground="#FFFFF8F8"
                                   Text="{Binding Symbol.TickerFull, Mode=OneWay}"
                                   HorizontalAlignment="Center"/>

                        <Border Grid.Column="1" Grid.Row="1" Margin="4"
                                BorderThickness="2" CornerRadius="4"
                                Background="{Binding TradeDirection, Converter={StaticResource TradeDirectionForLightText}}">
                            <TextBlock Margin="2" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontSize="12" Foreground="#FFFFF8F8"
                                       Text="{Binding TradeDirection, Mode=OneWay}"/>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxWidth="640">
                        <Grid Margin="4,4,4,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid DataContext="{Binding SelectedTrade}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto" MinWidth="96"/>
                                    <ColumnDefinition Width="*" MaxWidth="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto" MinWidth="96"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Column="0" Grid.Row="0" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.EntryTime}"/>
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding EntryTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}, Mode=OneWay}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="0" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.ExitTime}"/>
                                <TextBlock Grid.Column="4" Grid.Row="0"
                                           Text="{Binding ExitTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}, Mode=OneWay}" Margin="0,0,0,8"/>

                                <!-- Row 3: CancellationTime / IsFullyClosed -->
                                <TextBlock Grid.Column="0" Grid.Row="1" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.CancellationTime}"/>
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Text="{Binding CancellationTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}, Mode=OneWay}" Margin="0,0,0,8"/>


                                <!-- Row 4: PlannedEntryPrice / ExecutedEntryPrice -->
                                <TextBlock Grid.Column="0" Grid.Row="2" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.PlannedEntryPrice}"/>
                                <TextBlock Grid.Column="1" Grid.Row="2"
                                           Text="{Binding RoundedPlannedEntryPrice, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="2" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}"/>
                                <TextBlock Grid.Column="4" Grid.Row="2"
                                           Text="{Binding RoundedExecutedEntryPrice, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 5: OrderQuantity / FilledQuantity -->
                                <TextBlock Grid.Column="0" Grid.Row="3" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.OrderQuantity}"/>
                                <TextBlock Grid.Column="1" Grid.Row="3"
                                           Text="{Binding RoundedOrderQuantity, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="3" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.FilledQuantity}"/>
                                <TextBlock Grid.Column="4" Grid.Row="3"
                                           Text="{Binding RoundedFilledQuantity, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 6: PlannedPositionValue / ExecutedPositionValue -->
                                <TextBlock Grid.Column="0" Grid.Row="4" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.PlannedPositionValue}"/>
                                <TextBlock Grid.Column="1" Grid.Row="4"
                                           Text="{Binding PlannedPositionValue, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="4" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.ExecutedPositionValue}"/>
                                <TextBlock Grid.Column="4" Grid.Row="4"
                                           Text="{Binding ExecutedPositionValue, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 7: RemainingPositionValue -->
                                <TextBlock Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="5" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.RemainingPositionValue}"/>
                                <TextBlock Grid.Column="4" Grid.Row="5"
                                           Text="{Binding RemainingPositionValue, StringFormat=\{0:N2\}, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 8: PlannedSL / ExecutedSL -->
                                <TextBlock Grid.Column="0" Grid.Row="6" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.PlannedSL}"/>
                                <TextBlock Grid.Column="1" Grid.Row="6"
                                           Text="{Binding RoundedPlannedSL, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="3" Grid.Row="6" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"
                                           Text="{x:Static i18n:LocalizedStrings.ExecutedSL}"/>
                                <TextBlock Grid.Column="4" Grid.Row="6"
                                           Text="{Binding RoundedExecutedSL, Mode=OneWay}"
                                           Style="{StaticResource RightAlignedTextBlockStyle}" Margin="0,0,0,8"/>

                                <!-- Row 9: PlannedTP / ExecutedTP -->
                                <TextBlock Grid.Column="0" Grid.Row="7" FontWeight="Bold"
                                           Style="{StaticResource RightAlignedTextBlockStyle}"

<Window x:Class="TD.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TD.Models;assembly=OzzTradeDiary"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        mc:Ignorable="d"
        Title="Ozz Trade Diary"
        Height="700" Width="1200" MinHeight="520" MinWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="{x:Static i18n:ActionStrings.File}">
                <MenuItem Header="{x:Static i18n:ActionStrings.Import}" Command="{Binding ImportCommand}" />
                <MenuItem Header="{x:Static i18n:ActionStrings.Export}" Command="{Binding ExportCommand}" />
                <Separator />
                <MenuItem Header="{x:Static i18n:ActionStrings.Exit}" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Edit}">
                <MenuItem Header="{x:Static i18n:LocalizedStrings.AddTrade}" Command="{Binding TradeHistory.TradeCreateCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <MenuItem Header="{x:Static i18n:LocalizedStrings.EditTrade}" Command="{Binding TradeHistory.TradeEditCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <MenuItem Header="{x:Static i18n:LocalizedStrings.DeleteTrade}" Command="{Binding TradeHistory.TradeDeleteCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.View}">
                <MenuItem Header="{x:Static i18n:ActionStrings.Summary}" Command="{Binding ShowSummaryCommand}" />
                <MenuItem Header="{x:Static i18n:ActionStrings.Charts}" Command="{Binding ShowChartsCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Maintenance}">
                <MenuItem Header="{x:Static i18n:ActionStrings.ManageData}" Command="{Binding ShowMaintenanceCommand}">
                    <MenuItem.Icon>
                        <Path Fill="#0044D7" Data="{StaticResource gear-wide-connected}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{x:Static i18n:ActionStrings.Help}">
                <MenuItem Header="{x:Static i18n:ActionStrings.About}" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <Path Fill="#1D9BF0" Data="{StaticResource info-circle-fill}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Filter Toolbar -->
        <ToolBar Grid.Row="1" DataContext="{Binding TradeHistory}">
            <!-- Trading Account filter -->
            <TextBlock Text="{x:Static i18n:LocalizedStrings.TradingAccount}"
                       VerticalAlignment="Center" Margin="4,0,4,0"/>
            <ComboBox Width="160"
                      ItemsSource="{Binding TradingAccounts}"
                      DisplayMemberPath="Title"
                      SelectedValuePath="Id"
                      SelectedItem="{Binding SelectedTradingAccount}"
                      SelectedValue="{Binding QueryVM.ByTradingAccountId, Mode=TwoWay}">
                <ComboBox.Resources>
                    <CollectionViewSource x:Key="cvs" Source="{Binding TradingAccounts}"/>
                </ComboBox.Resources>
            </ComboBox>

            <Separator/>

            <!-- Symbol filter -->
            <TextBlock Text="{x:Static i18n:LocalizedStrings.Symbol}"
                       VerticalAlignment="Center" Margin="4,0,4,0"/>
            <ComboBox Width="140"
                      ItemsSource="{Binding Symbols}"
                      DisplayMemberPath="TickerFull"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding QueryVM.BySymbolId, Mode=TwoWay}"/>

            <Separator/>

            <!-- Entry date range -->
            <TextBlock Text="{x:Static i18n:LocalizedStrings.EntryTime}"
                       VerticalAlignment="Center" Margin="4,0,4,0"/>
            <DatePicker Width="120" SelectedDate="{Binding QueryVM.EntryTimeMin, Mode=TwoWay}"
                        ToolTip="From"/>
            <Viewbox Width="12" Height="12" Margin="2,0">
                <Path Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                      Data="{StaticResource arrow-right}"/>
            </Viewbox>
            <DatePicker Width="120" SelectedDate="{Binding QueryVM.EntryTimeMax, Mode=TwoWay}"
                        ToolTip="To"/>

            <Separator/>

            <!-- Load button -->
            <Button Command="{Binding TradesLoadCommand}"
                    ToolTip="{x:Static i18n:ActionStrings.Filter}"
                    Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="14" Height="14" Margin="0,0,4,0">
                        <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                              Data="{StaticResource search}"/>
                    </Viewbox>
                    <TextBlock Text="{x:Static i18n:ActionStrings.Filter}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Master / Detail content area -->
        <Grid Grid.Row="2" DataContext="{Binding TradeHistory}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- Trade list + pager (master) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding Trades}"
                          SelectedItem="{Binding SelectedTrade, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.EntryTime}"
                                            Binding="{Binding EntryTime, StringFormat=\{0:yyyy-MM-dd\}}"
                                            Width="100"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TradingAccount}"
                                            Binding="{Binding TradingAccount.Title}"
                                            Width="130"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Symbol}"
                                            Binding="{Binding Symbol.TickerFull}"
                                            Width="100"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TradeDirection}"
                                            Binding="{Binding TradeDirection}"
                                            Width="70"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.PlannedEntryPrice}"
                                            Binding="{Binding PlannedEntryPrice, StringFormat=\{0:N4\}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}"
                                            Binding="{Binding ExecutedEntryPrice, StringFormat=\{0:N4\}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}"
                                            Binding="{Binding RealizedProfitLoss, StringFormat=\{0:N2\}}"
                                            Width="100"/>
                        <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.IsFullyClosed}"
                                                Binding="{Binding IsFullyClosed}"
                                                Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pager bar -->
                <Border Grid.Row="1"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        Padding="4,3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Total count -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Total: " FontSize="12"/>
                            <TextBlock Text="{Binding QueryVM.TotalCount}" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Page navigation (centred) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Command="{Binding TradesPrevPageCommand}" Width="24" Height="24"
                                    Padding="2" ToolTip="Previous page">
                                <Viewbox Width="12" Height="12">
                                    <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Data="{StaticResource chevron-left}"/>
                                </Viewbox>
                            </Button>
                            <TextBlock VerticalAlignment="Center" Margin="8,0" FontSize="12">
                                <Run Text="Page "/>
                                <Run Text="{Binding QueryVM.Page}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <Button Command="{Binding TradesNextPageCommand}" Width="24" Height="24"
                                    Padding="2" ToolTip="Next page">
                                <Viewbox Width="12" Height="12">
                                    <Path Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Data="{StaticResource chevron-right}"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>

                        <!-- Page size selector -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Per page: " FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox SelectedValue="{Binding QueryVM.PageSize, Mode=TwoWay}"
                                      FontSize="12" Width="55" Height="22" Padding="4,1">
                                <sys:Int32>10</sys:Int32>
                                <sys:Int32>20</sys:Int32>
                                <sys:Int32>50</sys:Int32>
                                <sys:Int32>100</sys:Int32>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>

            <!-- Trade detail (detail pane) -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8" DataContext="{Binding SelectedTrade}">
                    <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"
                               Text="{x:Static i18n:LocalizedStrings.TradeHistory}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.TradingAccount}" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding TradingAccount.Title}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.Symbol}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding Symbol.TickerFull}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.EntryTime}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding EntryTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.TradeDirection}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding TradeDirection}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.PlannedEntryPrice}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding PlannedEntryPrice, StringFormat=\{0:N4\}}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding ExecutedEntryPrice, StringFormat=\{0:N4\}}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.PlannedSL}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding PlannedSL, StringFormat=\{0:N4\}}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.PlannedTP}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding PlannedTP, StringFormat=\{0:N4\}}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding RealizedProfitLoss, StringFormat=\{0:N2\}}"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.IsFullyClosed}" FontWeight="Bold" Margin="0,6,0,0"/>
                    <CheckBox IsChecked="{Binding IsFullyClosed, Mode=OneWay}" IsEnabled="False"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

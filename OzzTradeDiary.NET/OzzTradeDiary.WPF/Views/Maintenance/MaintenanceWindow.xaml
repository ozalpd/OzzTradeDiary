<Window x:Class="TD.WPF.Views.Maintenance.MaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TD.Models;assembly=OzzTradeDiary"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        xmlns:local="clr-namespace:TD.WPF.Views.Maintenance"
        mc:Ignorable="d"
        Title="Maintenance Window" Height="700" Width="1200" MinHeight="520" MinWidth="900">
    <Window.Resources>
        <ObjectDataProvider x:Key="MarketTypeValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:MarketType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="{x:Static i18n:LocalizedStrings.TradingAccount}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddTradingAccount}"
                                Click="AddTradingAccount_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveTradingAccounts_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshTradingAccounts_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding TradingAccounts}"
                              SelectedItem="{Binding SelectedTradingAccount}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="70" />
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="220" />
                            <DataGridCheckBoxColumn Header="IsActive" Binding="{Binding IsActive}" Width="120" />
                            <DataGridTextColumn Header="ExchangeCode" Binding="{Binding Exchange.ExchangeCode}" IsReadOnly="True" Width="130" />
                            <DataGridTextColumn Header="DisplayOrder" Binding="{Binding DisplayOrder}" Width="130" />
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="{x:Static i18n:LocalizedStrings.Exchange}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddExchange}"
                                Click="AddExchange_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveExchanges_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}" 
                                ToolTip="{x:Static i18n:LocalizedStrings.DeleteExchange}"
                                Background="#C80000"
                                Command="{Binding DeleteExchangeCommand}"
                                CommandParameter="{Binding}"
                                AutomationProperties.Name="Sil">
                            <Viewbox Width="14" Height="14">
                                <Path>
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Fill" Value="#F8F8F8"/>
                                            <Setter Property="Data" Value="{StaticResource trash3}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                    <Setter Property="Fill" Value="#C80000"/>
                                                    <Setter Property="Data" Value="{StaticResource trash3}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshExchanges_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Exchanges}"
                              SelectedItem="{Binding SelectedExchange}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="70" />
                            <DataGridTextColumn Header="ExchangeName" Binding="{Binding ExchangeName}" Width="260" />
                            <DataGridTextColumn Header="ExchangeCode" Binding="{Binding ExchangeCode}" Width="200" />
                            <DataGridTextColumn Header="DisplayOrder" Binding="{Binding DisplayOrder}" Width="130" />
                            <DataGridCheckBoxColumn Header="IsActive" Binding="{Binding IsActive}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="{x:Static i18n:LocalizedStrings.Symbol}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddSymbol}"
                                Click="AddSymbol_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveSymbols_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshSymbols_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Symbols}"
                              SelectedItem="{Binding SelectedSymbol}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="70" />
                            <DataGridTextColumn Header="TickerFull" Binding="{Binding TickerFull}" Width="220" />
                            <DataGridTextColumn Header="Ticker" Binding="{Binding Ticker}" Width="140" />
                            <DataGridTextColumn Header="BaseCurrency" Binding="{Binding BaseCurrency}" Width="130" />
                            <DataGridTextColumn Header="PriceCurrency" Binding="{Binding PriceCurrency}" Width="130" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="ExchangeCode" Binding="{Binding Exchange.ExchangeCode}" IsReadOnly="True" Width="130" />
                            <DataGridComboBoxColumn Header="MarketType"
                                                    SelectedItemBinding="{Binding MarketType}"
                                                    ItemsSource="{Binding Source={StaticResource MarketTypeValues}}"
                                                    Width="140" />
                            <DataGridCheckBoxColumn Header="IsActive" Binding="{Binding IsActive}" Width="120" />
                            <DataGridTextColumn Header="DisplayOrder" Binding="{Binding DisplayOrder}" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="{x:Static i18n:LocalizedStrings.Currency}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddCurrency}"
                                Click="AddCurrency_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveCurrencies_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshCurrencies_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding SelectedCurrency}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="70" />
                            <DataGridTextColumn Header="CurrencyTicker" Binding="{Binding CurrencyTicker}" Width="180" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="DisplayOrder" Binding="{Binding DisplayOrder}" Width="130" />
                            <DataGridCheckBoxColumn Header="IsActive" Binding="{Binding IsActive}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

<Window x:Class="TD.WPF.Views.Maintenance.MaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TD.Models;assembly=OzzTradeDiary"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        xmlns:local="clr-namespace:TD.WPF.Views.Maintenance"
        Title="Maintenance Window"
        Height="700" Width="1200" MinHeight="520" MinWidth="900"
        mc:Ignorable="d">
    <Window.Resources>
        <ObjectDataProvider x:Key="MarketTypeValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:MarketType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="{x:Static i18n:LocalizedStrings.TradingAccount}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddTradingAccount}"
                                Click="AddTradingAccount_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveTradingAccounts_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshTradingAccounts_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                        <Button ToolTip="{x:Static i18n:ActionStrings.Edit}"
                                Click="EditTradingAccounts_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle-28x24}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTradingAccount}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource pencil-square}"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding TradingAccounts}"
                              SelectedItem="{Binding SelectedTradingAccount}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Id}" Binding="{Binding Id}" IsReadOnly="True" Width="70" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Title}" Binding="{Binding Title}" Width="220" />
                            <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.IsActive}" Binding="{Binding IsActive}" Width="120" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExchangeCode}" Binding="{Binding Exchange.ExchangeCode}" IsReadOnly="True" Width="130" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.DisplayOrder}" Binding="{Binding DisplayOrder}" Width="130" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Notes}" Binding="{Binding Notes}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="{x:Static i18n:LocalizedStrings.Exchange}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddExchange}"
                                Click="AddExchange_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveExchanges_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshExchanges_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                        <Button ToolTip="{x:Static i18n:ActionStrings.Edit}"
                                Click="EditExchanges_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle-28x24}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedExchange}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource pencil-square}"/>
                            </Viewbox>
                        </Button>

                        <Border Width="32" Background="Transparent" />

                        <Button Style="{StaticResource IconButtonStyle-28x24}" 
                                ToolTip="{x:Static i18n:LocalizedStrings.DeleteExchange}"
                                Background="#C80000"
                                Command="{Binding DeleteExchangeCommand}"
                                CommandParameter="{Binding}"
                                AutomationProperties.Name="Sil">
                            <Viewbox Width="14" Height="14">
                                <Path>
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Fill" Value="#F8F8F8"/>
                                            <Setter Property="Data" Value="{StaticResource trash3}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                    <Setter Property="Fill" Value="#C80000"/>
                                                    <Setter Property="Data" Value="{StaticResource trash3}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Exchanges}"
                              SelectedItem="{Binding SelectedExchange}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Id}" Binding="{Binding Id}" IsReadOnly="True" Width="70" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExchangeName}" Binding="{Binding ExchangeName}" Width="260" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExchangeCode}" Binding="{Binding ExchangeCode}" Width="180" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.DefaultCurrency}" Binding="{Binding DefaultCurrency}" Width="180" />
                            <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.HasAnySymbol}" Binding="{Binding HasAnySymbol}" Width="120" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.DisplayOrder}" Binding="{Binding DisplayOrder}" Width="130" />
                            <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.IsActive}" Binding="{Binding IsActive}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="{x:Static i18n:LocalizedStrings.Symbol}" Height="20" VerticalAlignment="Top">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddSymbol}"
                                Click="AddSymbol_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveSymbols_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshSymbols_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                        <Button ToolTip="{x:Static i18n:ActionStrings.Edit}"
                                Click="EditSymbols_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle-28x24}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSymbol}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource pencil-square}"/>
                            </Viewbox>
                        </Button>
                        
                        <Border Width="32" Background="Transparent" />
                        <Border Width="32" Background="Transparent" /><!-- TODO: Replace with a delete button -->
                        <Grid Margin="8,1,0,0">
                            <TextBox x:Name="SymbolSearchTextBox"  Width="120"
                                     Text="{Binding SymbolSearchString, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{x:Static i18n:ActionStrings.Filter}" Grid.Column="1" Grid.Row="0" VerticalAlignment="Top" Margin="8,4,8,0"
                                       Foreground="#989898" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsFocused, ElementName=SymbolSearchTextBox}" Value="False" />
                                                    <Condition Binding="{Binding Text.Length, ElementName=SymbolSearchTextBox, FallbackValue=0}" Value="0" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="8,1,0,0">
                            <ComboBox x:Name="FilterByExchangeCombo"
                                      Width="120"
                                      ItemsSource="{Binding SymbolExchanges}"
                                      SelectedItem="{Binding SelectedSymbolExchange}"
                                      Loaded="FilterByExchangeCombo_Loaded"
                                      DropDownOpened="FilterByExchangeCombo_DropDownOpened"
                                      DropDownClosed="FilterByExchangeCombo_DropDownClosed"
                                      SelectionChanged="FilterByExchangeCombo_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ExchangeCode}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock x:Name="FilterByExchangeTextBlock"
                                       Text="{x:Static i18n:ActionStrings.FilterByExchange}"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="FilterByExchangeTextBlock_MouseLeftButtonDown"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                        </Grid>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding FilteredSymbols}"
                              SelectedItem="{Binding SelectedSymbol}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Id}" Binding="{Binding Id}" IsReadOnly="True" Width="48" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.TickerFull}" Binding="{Binding TickerFull}" Width="180" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Ticker}" Binding="{Binding Ticker}" Width="120" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Description}" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.BaseCurrency}" Binding="{Binding BaseCurrency}" Width="64" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.PriceCurrency}" Binding="{Binding PriceCurrency}" Width="64" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.ExchangeCode}" Binding="{Binding Exchange.ExchangeCode}" IsReadOnly="True" Width="64" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.MarketType}" Binding="{Binding MarketType}" Width="112" />
                            <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.IsActive}" Binding="{Binding IsActive}" Width="64" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.DisplayOrder}" Binding="{Binding DisplayOrder}" Width="64" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="{x:Static i18n:LocalizedStrings.Currency}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:LocalizedStrings.AddCurrency}"
                                Click="AddCurrency_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource plus-circle}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Save}"
                                Click="SaveCurrencies_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource floppy-fill}"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle-28x24}"
                                ToolTip="{x:Static i18n:ActionStrings.Refresh}"
                                Click="RefreshCurrencies_Click">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource arrow-clockwise}"/>
                            </Viewbox>
                        </Button>
                        <Button ToolTip="{x:Static i18n:ActionStrings.Edit}"
                                Click="EditCurrencys_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle-28x24}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCurrency}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="14" Height="14">
                                <Path Fill="#0044D7" Data="{StaticResource pencil-square}"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding SelectedCurrency}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Id}" Binding="{Binding Id}" IsReadOnly="True" Width="70" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.CurrencyTicker}" Binding="{Binding CurrencyTicker}" Width="180" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Description}" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.DisplayOrder}" Binding="{Binding DisplayOrder}" Width="130" />
                            <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.IsActive}" Binding="{Binding IsActive}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

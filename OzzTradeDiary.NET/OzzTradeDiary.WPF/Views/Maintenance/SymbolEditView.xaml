<v:AbstractEditView x:Class="TD.WPF.Views.Maintenance.SymbolEditView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:local="clr-namespace:TD.WPF.Views.Maintenance"
                    xmlns:v="clr-namespace:TD.WPF.Views"
                    xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
                    Title="{x:Static i18n:LocalizedStrings.EditSymbol}"
                    Height="520" Width="420" MinHeight="520" MinWidth="420"
                    WindowStartupLocation="CenterOwner"
                    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.MarketType}" />
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,18"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding MarketType, Mode=OneWay}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.Ticker}" />
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,18"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding Ticker, Mode=OneWay}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.Exchange}" />
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,18"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding ExchangeCode, Mode=OneWay}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.TickerFull}" />
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,18"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding TickerFull, Mode=OneWay}" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.PriceCurrency}" />
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,18"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding PriceCurrency, Mode=OneWay}" />

        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.BaseCurrency}" />
        <TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,18"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding BaseCurrency, Mode=OneWay}" />

        


        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.DisplayOrder}" />
        <TextBox Grid.Row="6" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding DisplayOrder, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.IsActive}" />
        <CheckBox Grid.Row="7" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding IsActive}" />
        <Grid Grid.Row="8" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.Description}" />
            <TextBox Grid.Row="1"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static i18n:ActionStrings.OK}" Width="90" Margin="0,0,8,0" IsDefault="True" IsEnabled="{Binding IsValid}" Click="OkButton_Click" />
            <Button Content="{x:Static i18n:ActionStrings.Cancel}" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</v:AbstractEditView>

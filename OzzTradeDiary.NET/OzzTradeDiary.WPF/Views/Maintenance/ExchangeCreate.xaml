<Window x:Class="TD.WPF.Views.Maintenance.ExchangeCreate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TD.WPF.Views.Maintenance"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        Title="{x:Static i18n:LocalizedStrings.CreateExchange}"
        Height="300" Width="420" MinHeight="300" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        FocusManager.FocusedElement="{Binding ElementName=ExchangeNameTextBox}"
        mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.ExchangeName}" />
        <TextBox x:Name="ExchangeNameTextBox" Grid.Row="0" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding ExchangeName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.ExchangeCode}" />
        <TextBox Grid.Row="1" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding ExchangeCode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.DefaultCurrency}" />
        <TextBox Grid.Row="2" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding DefaultCurrency, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.DisplayOrder}" />
        <TextBox Grid.Row="3" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding DisplayOrder, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{x:Static i18n:LocalizedStrings.IsActive}" />
        <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding IsActive}" />

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static i18n:ActionStrings.OK}" Width="90" Margin="0,0,8,0" IsDefault="True" IsEnabled="{Binding IsValid}" Click="OkButton_Click" />
            <Button Content="{x:Static i18n:ActionStrings.Cancel}" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

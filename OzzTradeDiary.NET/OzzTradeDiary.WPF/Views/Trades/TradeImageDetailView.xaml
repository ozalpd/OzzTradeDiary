<Window x:Class="TD.WPF.Views.Trades.TradeImageDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TD.WPF.Views.Trades"
        xmlns:behaviors="clr-namespace:TD.WPF.Behaviors"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        Title="{x:Static i18n:LocalizedStrings.TradeImage}"
        Height="920" Width="1280" MinHeight="400" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d">
    <Grid Margin="2,2,2,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
       
        <!-- Image display -->
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#CCCCCC" Margin="-10,0,0,0">
            <Image behaviors:AsyncImageLoader.SourceUrl="{Binding ImageURL, Mode=OneWay}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <TextBlock Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="2,-2,0,-40" HorizontalAlignment="Center"
                   FontWeight="Bold" FontSize="32" Foreground="#A8FFFFFF"
                   Text="{Binding Category, Mode=OneWay}"/>
        <TextBlock Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="-2,2,0,-38" HorizontalAlignment="Center"
                   FontWeight="Bold" FontSize="32" Foreground="#A8FFFFFF"
                   Text="{Binding Category, Mode=OneWay}"/>
        <TextBlock Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,-36" HorizontalAlignment="Center"
                   FontWeight="Bold" FontSize="32"
                   Text="{Binding Category, Mode=OneWay}"/>
        <!-- Metadata -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
           
            <TextBlock Grid.Column="0" Grid.Row="0" FontWeight="Bold" Margin="0,0,6,4" Text="{x:Static i18n:LocalizedStrings.ImageURL}"/>
            <TextBlock Grid.Column="1" Grid.Row="0" TextWrapping="Wrap" Text="{Binding ImageURL, Mode=OneWay}"/>

            <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" TextWrapping="Wrap" Margin="0,0,0,4"
                       Text="{Binding Notes, Mode=OneWay}"/>
        </Grid>
    </Grid>
</Window>

<base:AbstractEditView x:Class="TD.WPF.Views.Trades.TradeEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TD.WPF.Views.Trades"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        xmlns:base="clr-namespace:TD.WPF.Views"
        Title="{x:Static i18n:LocalizedStrings.EditTrade}"
        Height="840" Width="420" MinHeight="840" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.TradingAccount}"/>
        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding TradingAccount.Title, Mode=OneWay}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.Symbol}"/>
        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding Symbol.TickerFull, Mode=OneWay}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.EntryTime}"/>
        <TextBox x:Name="EntryTimeDatePicker" Grid.Row="2" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding EntryTime, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.EntryMethod}"/>
        <ComboBox x:Name="EntryMethodComboBox" Grid.Row="3" Grid.Column="1"
                  Style="{StaticResource ValidationComboBoxStyle}"
                  ItemsSource="{Binding EntryMethodValues}"
                  DisplayMemberPath="DisplayValue"
                  SelectedValuePath="Value"
                  SelectedValue="{Binding EntryMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.TradeDirection}"/>
        <ComboBox x:Name="TradeDirectionComboBox" Grid.Row="4" Grid.Column="1"
                  Style="{StaticResource ValidationComboBoxStyle}"
                  ItemsSource="{Binding TradeDirectionValues}"
                  DisplayMemberPath="DisplayValue"
                  SelectedValuePath="Value"
                  SelectedValue="{Binding TradeDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.IsFullyClosed}"/>
        <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding IsFullyClosed}" />

        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.OrderQuantity}"/>
        <TextBox x:Name="OrderQuantityTextBox" Grid.Row="6" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding OrderQuantity, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.FilledQuantity}"/>
        <TextBox x:Name="FilledQuantityTextBox" Grid.Row="7" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding FilledQuantity, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.PlannedEntryPrice}"/>
        <TextBox x:Name="PlannedEntryPriceTextBox" Grid.Row="8" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding PlannedEntryPrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}"/>
        <TextBox x:Name="ExecutedEntryPriceTextBox" Grid.Row="9" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding ExecutedEntryPrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.PlannedPositionValue}"/>
        <TextBox x:Name="PlannedPositionValueTextBox" Grid.Row="10" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding PlannedPositionValue, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.ExecutedPositionValue}"/>
        <TextBox x:Name="ExecutedPositionValueTextBox" Grid.Row="11" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding ExecutedPositionValue, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.PlannedProfitLoss}"/>
        <TextBox x:Name="PlannedProfitLossTextBox" Grid.Row="12" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding PlannedProfitLoss, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}"/>
        <TextBox x:Name="RealizedProfitLossTextBox" Grid.Row="13" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding RealizedProfitLoss, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.PlannedTP}"/>
        <TextBox x:Name="PlannedTPTextBox" Grid.Row="14" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding PlannedTP, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.ExecutedTP}"/>
        <TextBox x:Name="ExecutedTPTextBox" Grid.Row="15" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding ExecutedTP, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="16" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.PlannedRiskAmount}"/>
        <TextBox x:Name="PlannedRiskAmountTextBox" Grid.Row="16" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding PlannedRiskAmount, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="17" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.PlannedSL}"/>
        <TextBox x:Name="PlannedSLTextBox" Grid.Row="17" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding PlannedSL, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="18" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.ExecutedSL}"/>
        <TextBox x:Name="ExecutedSLTextBox" Grid.Row="18" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding ExecutedSL, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="19" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.UpdatedAt}"/>
        <TextBox x:Name="UpdatedAtDatePicker" Grid.Row="19" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding UpdatedAt, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <StackPanel Grid.Row="20" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static i18n:ActionStrings.OK}" Width="90" Margin="0,0,8,0" IsDefault="True" IsEnabled="{Binding IsValid}" Click="OkButton_Click" />
            <Button Content="{x:Static i18n:ActionStrings.Cancel}" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</base:AbstractEditView>
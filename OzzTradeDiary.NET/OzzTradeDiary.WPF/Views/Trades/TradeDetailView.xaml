<Window x:Class="TD.WPF.Views.Trades.TradeDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TD.WPF.Views.Trades"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        Title="{x:Static i18n:LocalizedStrings.Trade}"
        Height="710" Width="720" MinHeight="710" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d">
    <Grid Margin="8,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" MinWidth="96" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" MinWidth="96" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.TradingAccount}"/>
        <TextBlock Grid.Column="1" Grid.Row="0"
                   Text="{Binding TradingAccount.Title, Mode=OneWay}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="0" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.Symbol}"/>
        <TextBlock Grid.Column="4" Grid.Row="0"
                   Text="{Binding Symbol.TickerFull, Mode=OneWay}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="1" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.EntryMethod}"/>
        <TextBlock Grid.Column="1" Grid.Row="1"
                   Text="{Binding EntryMethod, Mode=OneWay}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="1" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.TradeDirection}"/>
        <TextBlock Grid.Column="4" Grid.Row="1"
                   Text="{Binding TradeDirection, Mode=OneWay}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="2" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.PlannedEntryPrice}"/>
        <TextBlock Grid.Column="1" Grid.Row="2"
                   Text="{Binding RoundedPlannedEntryPrice, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="2" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.ExecutedEntryPrice}"/>
        <TextBlock Grid.Column="4" Grid.Row="2"
                   Text="{Binding RoundedExecutedEntryPrice, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="3" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.EntryTime}"/>
        <TextBlock Grid.Column="1" Grid.Row="3"
                   Text="{Binding EntryTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}, Mode=OneWay}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="3" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.ExitTime}"/>
        <TextBlock Grid.Column="4" Grid.Row="3"
                   Text="{Binding ExitTime, StringFormat=\{0:yyyy-MM-dd HH:mm\}, Mode=OneWay}"
                   Margin="0,0,0,8"/>
<!--
        <TextBlock Grid.Column="0" Grid.Row="4" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.RealizedR}"/>
        <TextBlock Grid.Column="1" Grid.Row="4"
                   Text="{Binding RealizedR, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>
-->
        <TextBlock Grid.Column="3" Grid.Row="4" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.IsFullyClosed}"/>
        <CheckBox Grid.Row="4" Grid.Column="4" Margin="0,0,0,8"
                  IsEnabled="False" IsChecked="{Binding IsFullyClosed, Mode=OneWay}" />

        <TextBlock Grid.Column="0" Grid.Row="5" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.PlannedPositionValue}"/>
        <TextBlock Grid.Column="1" Grid.Row="5"
                   Text="{Binding PlannedPositionValue, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="5" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.ExecutedPositionValue}"/>
        <TextBlock Grid.Column="4" Grid.Row="5"
                   Text="{Binding ExecutedPositionValue, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="6" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.OrderQuantity}"/>
        <TextBlock Grid.Column="1" Grid.Row="6"
                   Text="{Binding RoundedOrderQuantity, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="6" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.FilledQuantity}"/>
        <TextBlock Grid.Column="4" Grid.Row="6"
                   Text="{Binding RoundedFilledQuantity, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="7" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.PlannedSL}"/>
        <TextBlock Grid.Column="1" Grid.Row="7"
                   Text="{Binding RoundedPlannedSL, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="7" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.ExecutedSL}"/>
        <TextBlock Grid.Column="4" Grid.Row="7"
                   Text="{Binding RoundedExecutedSL, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="8" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.PlannedProfit}"/>
        <TextBlock Grid.Column="1" Grid.Row="8"
                   Text="{Binding PlannedProfit, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="8" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.RealizedProfitLoss}"/>
        <TextBlock Grid.Column="4" Grid.Row="8"
                   Text="{Binding RealizedProfitLoss, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="9" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.PlannedTP}"/>
        <TextBlock Grid.Column="1" Grid.Row="9"
                   Text="{Binding RoundedPlannedTP, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="9" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.ExecutedTP}"/>
        <TextBlock Grid.Column="4" Grid.Row="9"
                   Text="{Binding RoundedExecutedTP, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="10" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.PlannedRiskAmount}"/>
        <TextBlock Grid.Column="1" Grid.Row="10"
                   Text="{Binding PlannedRiskAmount, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="10" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.RealizedRiskAmount}"/>
        <TextBlock Grid.Column="4" Grid.Row="10"
                   Text="{Binding RealizedRiskAmount, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="11" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.PlannedRiskRewardRatio}"/>
        <TextBlock Grid.Column="1" Grid.Row="11"
                   Text="{Binding PlannedRiskRewardRatio, StringFormat=\{0:N2\}, Mode=OneWay}"
                   Style="{StaticResource RightAlignedTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="3" Grid.Row="11" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.UpdatedAt}"/>
        <TextBlock Grid.Column="4" Grid.Row="11"
                   Text="{Binding UpdatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}, Mode=OneWay}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="12" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.SetupNotes}"/>
        <TextBlock Grid.Column="1" Grid.Row="12"
                   Grid.ColumnSpan="5" TextWrapping="Wrap"
                   Text="{Binding SetupNotes, Mode=OneWay}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Column="0" Grid.Row="13" FontWeight="Bold"
                   Style="{StaticResource RightAlignedTextBlockStyle}" Text="{x:Static i18n:LocalizedStrings.ReviewNotes}"/>
        <TextBlock Grid.Column="1" Grid.Row="13"
                   Grid.ColumnSpan="5" TextWrapping="Wrap"
                   Text="{Binding ReviewNotes, Mode=OneWay}"
                   Margin="0,0,0,8"/>
    </Grid>
</Window>

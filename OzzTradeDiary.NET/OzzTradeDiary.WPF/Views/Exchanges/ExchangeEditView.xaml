<base:AbstractEditView x:Class="TD.WPF.Views.Exchanges.ExchangeEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TD.WPF.Views.Exchanges"
        xmlns:i18n="clr-namespace:TD.i18n;assembly=OzzTradeDiary.i18n"
        xmlns:base="clr-namespace:TD.WPF.Views"
        Title="{x:Static i18n:LocalizedStrings.EditExchange}"
        Height="420" Width="420" MinHeight="420" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d">
    <Grid Margin="8,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.ExchangeName}"/>
        <TextBox x:Name="ExchangeNameTextBox" Grid.Row="0" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding ExchangeName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.ExchangeCode}"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding ExchangeCode, Mode=OneWay}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.CountryCode}"/>
        <TextBox x:Name="CountryCodeTextBox" Grid.Row="2" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding CountryCode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.DefaultCurrency}"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                 Text="{Binding DefaultCurrency.CurrencyTicker, Mode=OneWay}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.Timezone}"/>
        <TextBox x:Name="TimezoneTextBox" Grid.Row="4" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding Timezone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.IsAlwaysOpen}"/>
        <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,20" IsChecked="{Binding IsAlwaysOpen}" />

        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.DisplayOrder}"/>
        <TextBox x:Name="DisplayOrderTextBox" Grid.Row="6" Grid.Column="1"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{Binding DisplayOrder, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource RightAlignedTextBlockStyle}"
                   Text="{x:Static i18n:LocalizedStrings.IsActive}"/>
        <CheckBox Grid.Row="7" Grid.Column="1" Margin="0,0,0,20" IsChecked="{Binding IsActive}" />

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6" VerticalAlignment="Bottom">
            <Button Content="{x:Static i18n:ActionStrings.OK}" Width="90" Margin="0,0,18,0" IsDefault="True" IsEnabled="{Binding IsValid}" Click="OkButton_Click" />
            <Button Content="{x:Static i18n:ActionStrings.Cancel}" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</base:AbstractEditView>
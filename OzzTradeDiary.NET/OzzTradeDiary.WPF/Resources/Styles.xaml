<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Trade Direction Styles -->
    <Style x:Key="TradeDirectionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FFFFF8F8"/>
        <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForLightText}}"/>
    </Style>

    <Style x:Key="TradeDirectionCellStyleLight" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#002020"/>
        <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForDarkText}}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="#FFFFF8F8"/>
                <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForLightText}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TradeDirectionCellStyleDark" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#FFFFF8F8"/>
        <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForLightText}}"/>
    </Style>


    <!-- TextBlock Style: for detail pane -->
    <Style x:Key="DetailTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="4,2,2,8"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>
    <Style x:Key="DetailNumTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource DetailTextBlockStyle}">
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <!-- Trade Status Styles -->
    <Style x:Key="TradeStatusTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#002020"/>
        <Setter Property="Background" Value="{Binding TradeStatus, Converter={StaticResource TradeStatusLightBgColor}}"/>
    </Style>

    <Style x:Key="TradeStatusCellStyle" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#002020"/>
        <Setter Property="Background" Value="{Binding TradeStatus, Converter={StaticResource TradeStatusLightBgColor}}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="#EBEBEB"/>
                <Setter Property="Background" Value="#0078D7"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RightAlignedDataGridTextBlockStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Padding" Value="2,0"/>
    </Style>
    <Style x:Key="RightAlignedCellStyle" TargetType="DataGridCell">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Padding" Value="2,0,0,0"/>
    </Style>

    <!-- Profit/Loss Styles -->
    <Style x:Key="NetProfitLossTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FFFFF8F8"/>
        <Setter Property="Background" Value="{Binding NetProfitLoss, Converter={StaticResource NetProfitLossForLightText}}"/>
        <Setter Property="Padding" Value="2,1"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="NetProfitLossCellStyleLight" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#002020"/>
        <Setter Property="Background" Value="{Binding NetProfitLoss, Converter={StaticResource NetProfitLossForDarkText}}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="#FFFFF8F8"/>
                <Setter Property="Background" Value="{Binding NetProfitLoss, Converter={StaticResource NetProfitLossForSelectedCell}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NetProfitLossCellStyleDark" TargetType="DataGridCell" BasedOn="{StaticResource RightAlignedCellStyle}">
        <Setter Property="Foreground" Value="#FFFFF8F8"/>
        <Setter Property="Background" Value="{Binding NetProfitLoss, Converter={StaticResource NetProfitLossForLightText}}"/>
    </Style>

</ResourceDictionary>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style x:Key="TradeDirectionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FFFFF8F8"/>
        <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForLightText}}"/>
    </Style>

    <Style x:Key="TradeDirectionCellStyleLight" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#002020"/>
        <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForDarkText}}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="#FFFFF8F8"/>
                <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForLightText}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TradeDirectionCellStyleDark" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#FFFFF8F8"/>
        <Setter Property="Background" Value="{Binding TradeDirection, Converter={StaticResource TradeDirectionForLightText}}"/>
    </Style>
    
    <Style x:Key="TradeStatusTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#002020"/>
        <Setter Property="Background" Value="{Binding TradeStatus, Converter={StaticResource TradeStatusLightBgColor}}"/>
    </Style>

    <Style x:Key="TradeStatusCellStyle" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#002020"/>
        <Setter Property="Background" Value="{Binding TradeStatus, Converter={StaticResource TradeStatusLightBgColor}}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{Binding TradeStatus, Converter={StaticResource TradeStatusLightBgColor}}"/>
                <Setter Property="Background" Value="#202068"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
</ResourceDictionary>
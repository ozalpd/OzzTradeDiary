<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:TD.WPF.Converters">
    <converters:TradeStatusToColor x:Key="TradeStatusLightBgColor"/>
    <converters:TradeDirectionToColor x:Key="TradeDirectionForDarkText"/>
    <converters:TradeDirectionToColor x:Key="TradeDirectionForLightText" ColorForLong="#FF00C000" ColorForShort="#FFC80000"/>
    <converters:BoolToColor x:Key="TrueGreenFalseRed" ColorForFalseValue="#FFD00000" ColorForTrueValue="#FF00C000" />
    <converters:BoolToColor x:Key="TruePinkFalseWhite" ColorForFalseValue="White" ColorForTrueValue="#FFFFCFCF" />
    <converters:ProfitLossToColor x:Key="NetProfitLossForDarkText" ColorForProfit="#FFB8F4B8" ColorForLoss="#FFF8B8B8" ColorForDefault="Transparent"/>
    <converters:ProfitLossToColor x:Key="NetProfitLossForLightText" ColorForProfit="#FF00C000" ColorForLoss="#FFC80000" ColorForDefault="Transparent"/>
    <converters:ProfitLossToColor x:Key="NetProfitLossForSelectedCell" ColorForProfit="#FF00C000" ColorForLoss="#FFC80000" ColorForDefault="#0078D7"/>
</ResourceDictionary>
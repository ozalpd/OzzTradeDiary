<UserControl x:Class="TD.WPF.Controls.DateTimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TD.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="28" d:DesignWidth="300" Height="28">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="20" />
        </Grid.ColumnDefinitions>
        <DatePicker x:Name="datePicker" Grid.Column="0" VerticalAlignment="Stretch" VerticalContentAlignment="Center" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
        <TextBox x:Name="hourTextBox" Grid.Column="1" VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                 PreviewTextInput="IntegerTextBox_PreviewTextInput" LostFocus="HourTextBox_LostFocus"/>
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Tag="HourUp" Click="HourMinuteButton_Click">
                <Viewbox Width="10" Height="10">
                    <Path Margin="-4,-3,-2,2">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="#0044D7"/>
                                <Setter Property="Data" Value="{StaticResource caret-up-fill}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                        <Setter Property="Fill" Value="#A0A0A0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="#000000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
            <Button Grid.Row="1" Tag="HourDown" Click="HourMinuteButton_Click">
                <Viewbox Width="10" Height="10">
                    <Path Margin="-4,-4,-2,3">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="#0044D7"/>
                                <Setter Property="Data" Value="{StaticResource caret-down-fill}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                        <Setter Property="Fill" Value="#A0A0A0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="#000000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
        </Grid>
        <TextBox x:Name="minuteTextBox" Grid.Column="3" VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                 PreviewTextInput="IntegerTextBox_PreviewTextInput" LostFocus="MinuteTextBox_LostFocus"/>
        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Tag="MinuteUp" Click="HourMinuteButton_Click">
                <Viewbox Width="10" Height="10">
                    <Path Margin="-4,-3,-2,2">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="#0044D7"/>
                                <Setter Property="Data" Value="{StaticResource caret-up-fill}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                        <Setter Property="Fill" Value="#A0A0A0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="#000000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
            <Button Grid.Row="1" Tag="MinuteDown" Click="HourMinuteButton_Click">
                <Viewbox Width="10" Height="10">
                    <Path Margin="-4,-4,-2,3">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="#0044D7"/>
                                <Setter Property="Data" Value="{StaticResource caret-down-fill}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                        <Setter Property="Fill" Value="#A0A0A0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="#000000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
        </Grid>
    </Grid>
</UserControl>
